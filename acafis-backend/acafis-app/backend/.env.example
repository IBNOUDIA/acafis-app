# ══ SERVEUR ══
PORT=5000
NODE_ENV=development

# ══ MONGODB ══
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/acafis-app

# ══ JWT ══
JWT_SECRET=votre_secret_jwt_tres_long_et_securise
JWT_REFRESH_SECRET=votre_secret_refresh_jwt
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# ══ EMAIL (Resend) ══
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@coop-acafis.com

# ══ CLOUDINARY (fichiers/photos) ══
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ══ CLIENT ══
CLIENT_URL=https://app.coop-acafis.com
